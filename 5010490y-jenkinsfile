pipeline {
    agent any

    stages {

        stage('ST1: Setup Environment') {
            steps {
                echo 'ST1: Setup Release Environment Completed.'
            }
        }

        stage('ST2: Create Server1 Container') {
            steps {
                script {
                    sh '''
                        if [ "$(docker ps -aq -f name=server1)" ]; then
                            docker rm -f server1 >/dev/null 2>&1
                        fi

                        # Run container from svr-image-5010490y in detached mode
                        docker run -d --name server1 -p 32700:80 svr-image-5010490y >/dev/null
                    '''
                    echo 'ST2: Server1 is successfully created'
                }
            }
        }

        stage('ST3: Health Check') {
            steps {
                script {
                    def status = sh(script: "docker inspect -f '{{.State.Running}}' server1", returnStdout: true).trim()
                    if (status == 'true') {
                        echo 'ST3: Server1 is healthy – Health check done'
                    } else {
                        error('ST3: Health check failed. Aborting pipeline.')
                    }
                }
            }
        }

        stage('ST4: Security Scrutinises') {
            parallel {
                stage('ST4A: SQLI Check') {
                    steps {
                        echo 'ST4A: SQLI Check Completed'
                    }
                }
                stage('ST4B: XSS Check') {
                    steps {
                        echo 'ST4B: XSS Check Completed'
                    }
                }
                stage('ST4-Main') {
                    steps {
                        echo 'ST4-Parallel: Security Scrutinises'
                    }
                }
            }
        }

        stage('ST5: User Confirmation') {
            steps {
                script {
                    def userChoice = input(
                        id: 'userInput', message: 'Continue the pipeline?', ok: 'Proceed',
                        parameters: [
                            choice(choices: ['Proceed', 'Abort'], description: 'Choose to proceed or abort the pipeline', name: 'UserDecision')
                        ]
                    )
                    if (userChoice == 'Abort') {
                        error('ST5: Pipeline Aborted by user.')
                    } else {
                        echo 'ST5 : Continue the pipeline.'
                    }
                }
            }
        }

        stage('ST6: Next Phase Prep') {
            steps {
                echo 'ST6 : Ready for next phase'
            }
        }

    }

    post {
        always {
            echo 'Pipeline execution complete.'
        }
    }
}
