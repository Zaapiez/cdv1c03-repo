pipeline {
    agent any

    stages {
        stage('Setup Environment') {
            steps {
                echo 'Setup Release Environment Completed.'
            }
        }

        stage('Create Server1 Container') {
            steps {
                script {
                    sh '''
                        docker rm -f server1 >/dev/null 2>&1 || true
                        docker run -d --name server1 -p 32700:80 svr-image-5010490y >/dev/null || exit 1
                    '''
                    echo 'Server1 container created successfully.'
                }
            }
        }

        stage('Health Check') {
            steps {
                script {
                    def running = sh(script: "docker inspect -f '{{.State.Running}}' server1", returnStdout: true).trim()
                    if (running == 'true') {
                        echo 'Server1 is running – Health check passed.'
                    } else {
                        error('Health check failed – Container is not running.')
                    }
                }
            }
        }

        stage('Security Checks') {
            parallel {
                stage('SQL Injection Check') {
                    steps {
                        echo 'SQL Injection Check Completed.'
                    }
                }
                stage('XSS Check') {
                    steps {
                        echo 'XSS Check Completed.'
                    }
                }
            }
        }

        stage('User Confirmation') {
            steps {
                script {
                    def decision = input(
                        message: 'Continue the pipeline?',
                        parameters: [choice(name: 'UserDecision', choices: ['Proceed', 'Abort'], description: 'Choose an action')]
                    )
                    if (decision == 'Abort') {
                        error('Pipeline Aborted by User.')
                    }
                    echo 'User chose to proceed.'
                }
            }
        }

        stage('Next Phase Preparation') {
            steps {
                echo 'Ready for next phase.'
            }
        }
    }

    post {
        always {
            echo 'Pipeline execution complete.'
        }
    }
}
